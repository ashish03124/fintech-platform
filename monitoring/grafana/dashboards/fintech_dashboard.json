{
  "dashboard": {
    "title": "FinTech Platform Dashboard",
    "panels": [
      {
        "title": "Real-time Transaction Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(transactions_processed_total[5m])",
            "legendFormat": "Transactions/sec"
          }
        ]
      },
      {
        "title": "AI Response Time",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(ai_response_time_seconds_bucket[5m]))",
            "legendFormat": "95th percentile"
          }
        ]
      },
      {
        "title": "Active WebSocket Connections",
        "type": "stat",
        "targets": [
          {
            "expr": "active_websocket_connections",
            "legendFormat": "Connections"
          }
        ]
      },
      {
        "title": "Fraud Detection Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "fraud_predictions_total",
            "legendFormat": "Fraud Predictions"
          }
        ]
      }
    ]
  }
}